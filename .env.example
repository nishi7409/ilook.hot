# ─── Required ──────────────────────────────────────────────
DATABASE_URL=postgresql://ilook:ilook_secret@localhost:5432/ilook

# ─── Optional (API) ───────────────────────────────────────
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins
# Set to your production domain(s) when deploying
# ALLOWED_ORIGINS=https://ilook.hot

# USDA FoodData Central API key (free at https://fdc.nal.usda.gov/api-key-signup.html)
# The demo key works but has lower rate limits
# USDA_API_KEY=DEMO_KEY

# ─── Optional (Docker / Self-hosting) ─────────────────────
# POSTGRES_PASSWORD=ilook_secret
